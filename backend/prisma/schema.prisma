// =============================================================
// PRISMA SCHEMA — Hệ thống Quản lý Quán Cà Phê Đa Kênh
// MySQL database · Generated from db_cafe_test.sql
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── USER & AUTH ────────────────────────────────────────────

model NguoiDung {
  maNguoiDung       String    @id @default(cuid())
  hoTen             String
  diaChi            String?
  soDienThoai       String?   @unique
  matKhau           String?
  email             String?   @unique
  supabaseId        String?   @db.Char(36)
  authProvider      String    @default("LOCAL")
  avatarUrl         String?   @db.VarChar(500)
  ngaySinh          DateTime? @db.Date
  gioiTinh          String?
  verificationToken String?   @db.VarChar(64)
  forgetToken       String?   @db.VarChar(64)
  ngayTao           DateTime  @default(now())
  isDeleted         Boolean   @default(false)

  khachHang   KhachHang?
  nhanVien    NhanVien?
  danhGia     DanhGia[]
  yeuThich    YeuThich[]
  gioHang     GioHang[]
  diaChiGiao  DiaChiGiaoHang[]

  @@map("NguoiDung")
}

model VaiTro {
  maVaiTro       String     @id @default(cuid())
  tenVaiTro      String
  danhSachQuyen  String     @db.Text
  nhanVien       NhanVien[]

  @@map("VaiTro")
}

// ─── CUSTOMERS ──────────────────────────────────────────────

model KhachHang {
  maKhachHang   String  @id
  hoTen         String
  soDienThoai   String

  nguoiDung        NguoiDung       @relation(fields: [maKhachHang], references: [maNguoiDung])
  khachThanhVien   KhachThanhVien?
  khachVangLai     KhachVangLai?
  donHang          DonHang[]

  @@map("KhachHang")
}

model KhachThanhVien {
  maKhachHang    String   @id
  hangThanhVien  String?
  diemThuong     Int      @default(0)
  ngayDangKy     DateTime @db.Date

  khachHang  KhachHang @relation(fields: [maKhachHang], references: [maKhachHang])

  @@map("KhachThanhVien")
}

model KhachVangLai {
  maKhachHang  String  @id
  thongTinTam  String?

  khachHang  KhachHang @relation(fields: [maKhachHang], references: [maKhachHang])

  @@map("KhachVangLai")
}

// ─── STAFF ──────────────────────────────────────────────────

model NhanVien {
  maNhanVien  String   @id
  hireDate    DateTime
  maVaiTro    String

  nguoiDung    NguoiDung    @relation(fields: [maNhanVien], references: [maNguoiDung])
  vaiTro       VaiTro       @relation(fields: [maVaiTro], references: [maVaiTro])
  caLamViec    CaLamViec[]
  bienBan      BienBanSuCo[]
  phieuKho     PhieuKho[]
  donHang      DonHang[]

  @@map("NhanVien")
}

model CaLamViec {
  maCa           String   @id @default(cuid())
  loaiCa         String
  thoiGianVaoCa  DateTime
  thoiGianRaCa   DateTime?
  maNhanVien     String

  nhanVien  NhanVien @relation(fields: [maNhanVien], references: [maNhanVien])

  @@map("CaLamViec")
}

model BienBanSuCo {
  maBienBan    String   @id @default(cuid())
  moTaSuCo     String   @db.VarChar(500)
  tienThietHai Decimal? @db.Decimal(18, 2)
  thoiGianLap  DateTime
  maNhanVien   String

  nhanVien  NhanVien @relation(fields: [maNhanVien], references: [maNhanVien])

  @@map("BienBanSuCo")
}

// ─── MENU ───────────────────────────────────────────────────

model DanhMucMon {
  maDanhMuc   String  @id @default(cuid())
  tenDanhMuc  String
  slug        String? @unique
  iconUrl     String? @db.VarChar(500)
  thuTu       Int     @default(0)
  trangThai   Boolean @default(true)

  mon  Mon[]

  @@map("DanhMucMon")
}

model Mon {
  maMon        String   @id @default(cuid())
  tenMon       String
  giaBan       Decimal  @db.Decimal(18, 2)
  maDanhMuc    String
  daXoa        Boolean  @default(false)
  slug         String?  @unique
  moTa         String?  @db.Text
  diemDanhGia  Float    @default(0)
  isNoiBat     Boolean  @default(false)
  ngayTao      DateTime @default(now())

  danhMuc          DanhMucMon           @relation(fields: [maDanhMuc], references: [maDanhMuc])
  hinhAnh          HinhAnhMon[]
  doUong           DoUong?
  doAn             DoAn?
  tuyChon          TuyChonMon[]
  dinhMuc          DinhMuc[]
  danhGia          DanhGia[]
  yeuThich         YeuThich[]
  chiTietDonHang   ChiTietDonHang[]
  chiTietGioHang   ChiTietGioHang[]

  @@map("Mon")
}

model HinhAnhMon {
  maHinhAnh  Int     @id @default(autoincrement())
  maMon      String
  urlAnh     String  @db.VarChar(500)
  laAnhChinh Boolean @default(false)
  thuTu      Int     @default(0)

  mon  Mon @relation(fields: [maMon], references: [maMon])

  @@map("HinhAnhMon")
}

model DoUong {
  maMon       String  @id
  mucDoDa     String?
  mucDoDuong  String?
  mucSize     String? @db.VarChar(10)

  mon  Mon @relation(fields: [maMon], references: [maMon])

  @@map("DoUong")
}

model DoAn {
  maMon        String @id
  thoiGianNau  Int?

  mon  Mon @relation(fields: [maMon], references: [maMon])

  @@map("DoAn")
}

model TuyChonMon {
  maTuyChon    String  @id @default(cuid())
  tenTuyChon   String
  loaiNhom     String
  giaCongThem  Decimal @db.Decimal(18, 2)

  mon              Mon[]
  chiTietTuyChon   ChiTietDonHang_TuyChon[]

  @@map("TuyChonMon")
}

model DanhGia {
  maDanhGia    Int      @id @default(autoincrement())
  maNguoiDung  String
  maMon        String
  soSao        Int?
  noiDung      String?  @db.Text
  ngayViet     DateTime @default(now())

  nguoiDung  NguoiDung @relation(fields: [maNguoiDung], references: [maNguoiDung])
  mon        Mon       @relation(fields: [maMon], references: [maMon])

  @@map("DanhGia")
}

model YeuThich {
  maNguoiDung  String
  maMon        String
  ngayThem     DateTime @default(now())

  nguoiDung  NguoiDung @relation(fields: [maNguoiDung], references: [maNguoiDung])
  mon        Mon       @relation(fields: [maMon], references: [maMon])

  @@id([maNguoiDung, maMon])
  @@map("YeuThich")
}

// ─── TABLES ─────────────────────────────────────────────────

model Ban {
  maBan     String @id @default(cuid())
  soBan     String @unique
  trangThai String // TRONG | DANG_PHUC_VU | CHO_DON

  donHang  DonHang[]

  @@map("Ban")
}

// ─── PROMOTIONS ─────────────────────────────────────────────

model KhuyenMai {
  maKM                  String   @id @default(cuid())
  giaTriGiam            Decimal  @db.Decimal(18, 2)
  ngayBatDau            DateTime
  ngayKetThuc           DateTime
  soLuongToiDa          Int?
  trangThai             Boolean  @default(true)
  loaiKhuyenMai         String   // PHAN_TRAM | TIEN_MAT
  dieuKienDonToiThieu   Decimal? @db.Decimal(18, 2)

  donHang  DonHang[]

  @@map("KhuyenMai")
}

// ─── ORDERS ─────────────────────────────────────────────────

model DonHang {
  maDonHang      String   @id @default(cuid())
  tongTien       Decimal? @db.Decimal(18, 2)
  trangThai      String   // CHO_XAC_NHAN | DANG_PHA_CHE | HOAN_THANH | HUY
  thoiGianTao    DateTime @default(now())
  loaiDonHang    String   // TAI_QUAN | MANG_VE | ONLINE | GRAB | SHOPEE
  daDongBo       Boolean  @default(false)
  maDonDoiTac    String?  @db.VarChar(100)
  soTheRung      String?
  maBan          String?
  maNhanVien     String?
  maKhachHang    String?
  maKM           String?
  maMayKDS       String?
  maMayPOS       String?
  maDiaChi       Int?
  phiVanChuyen   Decimal  @default(0) @db.Decimal(18, 2)
  tienGiamGia    Decimal  @default(0) @db.Decimal(18, 2)
  tongThanhToan  Decimal? @db.Decimal(18, 2)
  ghiChu         String?  @db.Text
  thongTinGuest  String?  @db.Text
  daTruKho       Boolean  @default(false)

  ban          Ban?            @relation(fields: [maBan], references: [maBan])
  nhanVien     NhanVien?       @relation(fields: [maNhanVien], references: [maNhanVien])
  khachHang    KhachHang?      @relation(fields: [maKhachHang], references: [maKhachHang])
  khuyenMai    KhuyenMai?      @relation(fields: [maKM], references: [maKM])
  diaChiGiao   DiaChiGiaoHang? @relation(fields: [maDiaChi], references: [maDiaChi])
  chiTiet      ChiTietDonHang[]
  thanhToan    ThanhToan?

  @@map("DonHang")
}

model ChiTietDonHang {
  maChiTiet           String  @id @default(cuid())
  maDonHang           String
  maMon               String
  soLuong             Int
  donGiaThoiDiemBan   Decimal @db.Decimal(18, 2)
  ghiChu              String? @db.VarChar(255)

  donHang    DonHang  @relation(fields: [maDonHang], references: [maDonHang])
  mon        Mon      @relation(fields: [maMon], references: [maMon])
  tuyChon    ChiTietDonHang_TuyChon[]

  @@map("ChiTietDonHang")
}

model ChiTietDonHang_TuyChon {
  maChiTiet  String
  maTuyChon  String

  chiTiet   ChiTietDonHang @relation(fields: [maChiTiet], references: [maChiTiet])
  tuyChon   TuyChonMon     @relation(fields: [maTuyChon], references: [maTuyChon])

  @@id([maChiTiet, maTuyChon])
  @@map("ChiTietDonHang_TuyChonMon")
}

// ─── PAYMENT ────────────────────────────────────────────────

model ThanhToan {
  maThanhToan         String   @id @default(cuid())
  maDonHang           String   @unique
  soTienGiaoDich      Decimal? @db.Decimal(18, 2)
  thoiGianThanhToan   DateTime
  trangThaiGiaoDich   String
  maMayInBill         String?
  maMayPOS            String?
  phuongThuc          String?  // TIEN_MAT | VNPAY | MOMO | THE_NGAN_HANG
  gatewayTransactionId String? @db.VarChar(255)
  gatewayName         String?
  expirationTime      DateTime?
  paymentUrl          String?  @db.Text
  errorCode           String?
  errorMessage        String?  @db.Text
  anhBienLai          String?  @db.VarChar(500)

  donHang            DonHang        @relation(fields: [maDonHang], references: [maDonHang])
  thanhToanTienMat   ThanhToanTienMat?
  thanhToanQR        ThanhToanQR?
  thanhToanThe       ThanhToanTheNganHang?
  transactionLog     TransactionLog[]
  refund             Refund[]

  @@map("ThanhToan")
}

model ThanhToanTienMat {
  maThanhToan   String  @id
  tienKhachDua  Decimal @db.Decimal(18, 2)

  thanhToan  ThanhToan @relation(fields: [maThanhToan], references: [maThanhToan])

  @@map("ThanhToanTienMat")
}

model ThanhToanQR {
  maThanhToan  String @id
  qrContent    String @db.VarChar(500)

  thanhToan  ThanhToan @relation(fields: [maThanhToan], references: [maThanhToan])

  @@map("ThanhToanQR")
}

model ThanhToanTheNganHang {
  maThanhToan  String @id
  tenNganHang  String

  thanhToan  ThanhToan @relation(fields: [maThanhToan], references: [maThanhToan])

  @@map("ThanhToanTheNganHang")
}

model TransactionLog {
  maLog                Int      @id @default(autoincrement())
  maThanhToan          String
  gatewayTransactionId String?  @db.VarChar(255)
  gatewayName          String?
  requestData          String?  @db.Text
  responseData         String?  @db.Text
  callbackData         String?  @db.Text
  status               String   @default("PENDING")
  createdAt            DateTime @default(now())

  thanhToan  ThanhToan @relation(fields: [maThanhToan], references: [maThanhToan])

  @@map("TransactionLog")
}

model Refund {
  maRefund         Int      @id @default(autoincrement())
  maThanhToan      String
  gatewayRefundId  String?  @db.VarChar(255)
  amount           Decimal  @db.Decimal(18, 2)
  status           String   @default("PENDING")
  reason           String?  @db.Text
  createdAt        DateTime @default(now())

  thanhToan  ThanhToan @relation(fields: [maThanhToan], references: [maThanhToan])

  @@map("Refund")
}

// ─── CART ───────────────────────────────────────────────────

model GioHang {
  maGioHang   Int      @id @default(autoincrement())
  maNguoiDung String?
  sessionId   String?  @db.VarChar(255)
  ngayTao     DateTime @default(now())

  nguoiDung     NguoiDung?       @relation(fields: [maNguoiDung], references: [maNguoiDung])
  chiTietGio    ChiTietGioHang[]

  @@map("GioHang")
}

model ChiTietGioHang {
  maChiTietGio  Int @id @default(autoincrement())
  maGioHang     Int
  maMon         String
  soLuong       Int @default(1)
  ghiChu        String? @db.VarChar(255)

  gioHang  GioHang @relation(fields: [maGioHang], references: [maGioHang])
  mon      Mon     @relation(fields: [maMon], references: [maMon])

  @@map("ChiTietGioHang")
}

model DiaChiGiaoHang {
  maDiaChi      Int     @id @default(autoincrement())
  maNguoiDung   String
  tenNguoiNhan  String?
  sdtNhan       String? @db.VarChar(20)
  soNhaDuong    String? @db.VarChar(255)
  phuongXa      String? @db.VarChar(100)
  quanHuyen     String? @db.VarChar(100)
  tinhThanh     String? @db.VarChar(100)
  macDinh       Boolean @default(false)

  nguoiDung  NguoiDung @relation(fields: [maNguoiDung], references: [maNguoiDung])
  donHang    DonHang[]

  @@map("DiaChiGiaoHang")
}

// ─── INVENTORY ──────────────────────────────────────────────

model NguyenLieu {
  maNguyenLieu    String   @id @default(cuid())
  tenNL           String
  tonKho          Float
  donVi           String
  tonKhoToiThieu  Float    @default(10)
  giaNhap         Decimal? @db.Decimal(18, 2)
  maNCC           String?
  moTa            String?  @db.VarChar(500)
  daXoa           Boolean  @default(false)
  ngayCapNhat     DateTime @default(now()) @updatedAt

  nhaCungCap   NhaCungCap?       @relation(fields: [maNCC], references: [maNCC])
  dinhMuc      DinhMuc[]
  chiTietPhieu ChiTietPhieuKho[]

  @@map("NguyenLieu")
}

model NhaCungCap {
  maNCC       String   @id @default(cuid())
  tenNCC      String
  congNo      Decimal  @default(0) @db.Decimal(18, 2)
  diaChi      String?  @db.VarChar(500)
  soDienThoai String?  @db.VarChar(20)
  email       String?  @db.VarChar(100)
  ghiChu      String?  @db.Text
  daXoa       Boolean  @default(false)
  ngayTao     DateTime @default(now())

  phieuKho    PhieuKho[]
  nguyenLieu  NguyenLieu[]

  @@map("NhaCungCap")
}

model DinhMuc {
  maDinhMuc       String @id @default(cuid())
  soLuongTieuHao  Float
  maMon           String
  maNguyenLieu    String

  mon         Mon        @relation(fields: [maMon], references: [maMon])
  nguyenLieu  NguyenLieu @relation(fields: [maNguyenLieu], references: [maNguyenLieu])

  @@map("DinhMuc")
}

model PhieuKho {
  maPhieu      String   @id @default(cuid())
  thoiGianLap  DateTime
  tongGiaTri   Decimal  @db.Decimal(18, 2)
  loaiPhieu    String   // NHAP | XUAT | HUY | BAN_HANG
  maNCC        String?
  maNhanVien   String
  maDonHang    String?
  ghiChu       String?  @db.Text

  nhaCungCap   NhaCungCap?       @relation(fields: [maNCC], references: [maNCC])
  nhanVien     NhanVien          @relation(fields: [maNhanVien], references: [maNhanVien])
  chiTiet      ChiTietPhieuKho[]

  @@map("PhieuKho")
}

model ChiTietPhieuKho {
  maPhieu       String
  maNguyenLieu  String
  soLuongThucTe Float
  donGia        Decimal @db.Decimal(18, 2)

  phieuKho    PhieuKho   @relation(fields: [maPhieu], references: [maPhieu])
  nguyenLieu  NguyenLieu @relation(fields: [maNguyenLieu], references: [maNguyenLieu])

  @@id([maPhieu, maNguyenLieu])
  @@map("ChiTietPhieuKho")
}

// ─── DEVICES ────────────────────────────────────────────────

model ThietBiNgoaiVi {
  maThietBi  String  @id @default(cuid())
  ipAddress  String
  status     Boolean @default(false)
  loai       String  // KDS | POS | MAY_IN | MAY_RUNG

  @@map("ThietBiNgoaiVi")
}

// ─── BANNER ─────────────────────────────────────────────────

model BannerQuangCao {
  id               Int      @id @default(autoincrement())
  tieuDe           String
  hinhAnhDesktop   String   @db.VarChar(500)
  hinhAnhMobile    String?  @db.VarChar(500)
  linkDich         String   @db.VarChar(500)
  viTri            String   // HOME_HERO | HOME_SIDE | ...
  thuTu            Int      @default(0)
  ngayBatDau       DateTime?
  ngayKetThuc      DateTime?
  trangThai        Boolean  @default(true)

  @@map("banner_quang_cao")
}
